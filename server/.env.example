# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net

# Optional: database name (defaults to "dropshipping")
MONGO_DB_NAME=dropshipping

# Server port
PORT=5000

# ============================================
# M-PESA INTEGRATION (Kenya STK Push Payments)
# ============================================

# M-Pesa API Consumer Key (from Safaricom Daraja)
MPESA_CONSUMER_KEY=your_consumer_key_here

# M-Pesa API Consumer Secret (from Safaricom Daraja)
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# M-Pesa Business Short Code (e.g., 174379 for sandbox)
MPESA_SHORT_CODE=174379

# M-Pesa Pass Key (from Safaricom for STK Push)
MPESA_PASS_KEY=your_pass_key_here

# Callback URL (where M-Pesa sends payment confirmation)
MPESA_CALLBACK_URL=http://localhost:5000/api/mpesa/callback

# ============================================
# SUPPLIER API CREDENTIALS
# ============================================

# Jumia Vendor Center API Key
JUMIA_API_KEY=your_jumia_api_key_here

# Jumia Vendor ID
JUMIA_VENDOR_ID=your_jumia_vendor_id_here

# Kilimall OpenAPI Key
KILIMALL_API_KEY=your_kilimall_api_key_here

# Kilimall Seller ID
KILIMALL_SELLER_ID=your_kilimall_seller_id_here

# ============================================
# SUPPLIER MARKETPLACE API KEYS (Optional)
# ============================================

# Amazon Selling Partner API (for order fulfillment)
# AMAZON_SP_API_KEY=
# AMAZON_SP_API_SECRET=
# AMAZON_SP_ROLE_ARN=

# Temu Partner API (if available)
# TEMU_API_KEY=

# AliExpress Dropship API (if using)
# ALIEXPRESS_API_KEY=
